# Codex Configuration File
# Copy to config/codex.toml and edit as needed.
# Environment variables override values in this file.
# See README.md for full documentation.

# [server]
# Granian ASGI server settings
# host = "0.0.0.0"
# port = 9810
# Number of worker processes. 1 is recommended for containerized environments.
# workers = 1
# HTTP version: "auto", "1", or "2"
# http = "auto"
# Enable websockets (required for Codex live updates)
# websockets = true
# HTTP path prefix for codex (e.g. "/codex" for reverse proxy sub-path)
# url_path_prefix = ""

# [logging]
# Log level: TRACE, DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL
# loglevel = "INFO"
# log_retention = "6 months"
# log_to_console = true
# log_to_file = true
# Directory for log files. Defaults to <config_dir>/logs.
# log_dir = ""

# [cache]
# Directory for the file-based cache (covers, query results, etc).
# Defaults to <config_dir>/cache.
# dir = ""

# [browser]
# DEPRECATED in 1.10+ — now configured in the Admin UI under
# "Browser Display → Browser Page Size". Existing TOML / env values
# are imported into the DB on first upgrade; the TOML key is still
# read as a fallback for fresh installs.
# max_obj_per_page = 100

# [throttle]
# DEPRECATED in 1.10+ — now configured in the Admin UI under the
# "Throttling" tab. Existing TOML / env values are imported into the
# DB on first upgrade; the TOML keys are still read as a fallback for
# fresh installs.
#
# Rate limiting (requests per minute). 0 = disabled.
# anon = 0
# user = 0
# opds = 0
# opensearch = 0
# Password reset requests per hour, per IP. Defaults to 5.
# reset_password = 5

# [email]
# Outbound email is now configured in the Admin UI under the "Email" tab,
# including SMTP credentials and a Test Send button. The TOML section
# below is kept as a fallback for first-boot defaults; once an admin
# saves the Email settings, the DB row wins for every send.
#
# When unset (no DB row and blank TOML), password-reset and email-
# verification features stay disabled and the related endpoints
# respond 404. Set `host` AND `from_address` (or `user`) to enable.
#
# IMPORTANT: codex.toml stores credentials in plain text. Restrict file
# permissions (chmod 600) and consider environment variable overrides
# (CODEX_EMAIL_PASSWORD) for secrets management systems. Values saved
# via the Admin UI are encrypted at rest.
#
# host = ""
# port = 587
# user = ""
# password = ""
# use_tls = true
# use_ssl = false
# timeout = 10
# Sender address. If blank, `user` is used as the From address. Many
# providers accept the auth user as sender; SES and similar require an
# explicit verified identity here.
# from_address = ""
# subject_prefix = "[Codex] "
#
# --- Provider examples (uncomment ONE block) ---
#
# Gmail (requires an App Password, not your account password):
# host = "smtp.gmail.com"
# port = 587
# user = "you@gmail.com"
# password = "xxxx xxxx xxxx xxxx"
# use_tls = true
# from_address = "you@gmail.com"
#
# Mailgun / SendGrid / generic SMTP relay:
# host = "smtp.mailgun.org"
# port = 587
# user = "postmaster@mg.example.com"
# password = "your-api-key"
# use_tls = true
# from_address = "no-reply@example.com"
#
# Amazon SES (from_address MUST be a verified SES identity):
# host = "email-smtp.us-east-1.amazonaws.com"
# port = 587
# user = "AKIAIOSFODNN7EXAMPLE"
# password = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# use_tls = true
# from_address = "no-reply@verified-domain.example.com"

# [auth]
# Allows authentication without authorization via the Remote-User header.
# Only enable if you have authorization in front of Codex. Dangerous.
# remote_user = false
# Log failed login attempts to a separate file. Useful as input for
# banning tools like fail2ban, CrowdSec, or sshguard. The IP-bearing line
# is written only to this file; codex.log still records the bare Django
# WARNING (no IP) so the failure is visible without exposing PII.
# Line format: "<ISO timestamp> | Failed login from <ip> user=<username>"
# Example fail2ban failregex:
#   ^\s*\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2} \| Failed login from <HOST> user=.*$
# failed_login_log = false
# Path to the failed-login log. Defaults to <log_dir>/failed_logins.log.
# failed_login_log_path = ""
# When behind a reverse proxy, trust X-Forwarded-For for the client IP.
# Disable if Codex is exposed directly (otherwise clients can forge their IP).
# failed_login_log_trust_forwarded_for = true

# [custom_covers]
# Maximum size (in megabytes) of a custom-cover upload. This setting
# is also exposed in the Admin UI under "Custom Covers"; the DB value
# wins when an admin saves it. The TOML key remains the fallback for
# fresh installs.
# max_upload_mb = 10

# ----------------------------------------------------------------------
# Expert tuning
#
# The sections below cover performance and diagnostics knobs that are
# rarely changed and intentionally kept out of the Admin UI. Defaults
# work for typical hosts; tune only if you have a specific reason to.

# [importer]
# Batch sizes for the library importer. SQLite caps at 32766 variables
# per query — most values below leave headroom against that limit.
# Lower the chunk and cache values on memory-constrained hosts; raise
# them on hosts with abundant RAM.
# delete_max_chunk_size = 2000
# filter_batch_size = 900
# search_sync_batch_memory_ratio = 3.2
# link_fk_batch_size = 30000
# link_m2m_batch_size = 20000
# update_comic_batch_size = 400
# sqlite_cache_kb = 524288
# chunk_mem_fraction = 0.25

# [librarian]
# Worker count for the cover-generation ProcessPoolExecutor. Image
# resize + WEBP encode are CPU-bound; default is min(cpu_count, 8).
# Drop to 2 on NAS-class hosts with 1–2 GB total RAM.
# cover_workers = 8

# [debug]
# Diagnostic toggles. Volume can be very high under load — leave off
# unless investigating an issue.
# log_auth_headers = false
# log_request = false
# log_response_time = false
# slow_query_limit = 0.5
